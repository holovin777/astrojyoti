---
const { services } = Astro.props;
---

<section class="section">
  <div class="container">
    <h2 class="section-title">Ціни</h2>

    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(250px,1fr)); margin-top:2rem;">
      {services.map((s:any) => (
        <div class="card" style="padding:1.5rem; text-align:center;">
          <h3>{s.title}</h3>
          <p style="font-size:1.5rem; color:var(--accent); margin:0.5rem 0;">
            {s.price}
          </p>
          {s.specialPrice && <p class="muted">{s.specialPrice}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
