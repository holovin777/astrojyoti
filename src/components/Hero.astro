---
const { name, role, heroSubtitle, contacts } = Astro.props;
---

<section class="section">
  <div class="container grid grid-2" style="align-items: center; gap: 2rem;">
    <div>
      <p style="margin: 0 0 0.8rem; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase;">
        AstroJyoti
      </p>

      <h1 style="font-size: clamp(2.4rem, 6vw, 4.8rem); line-height: 1.05; margin: 0 0 1rem;">
        {name}<br />{role}
      </h1>

      <p class="section-subtitle" style="font-size: 1.1rem; margin-bottom: 1.5rem;">
        {heroSubtitle}
      </p>

      <div style="display: flex; gap: 0.9rem; flex-wrap: wrap;">
        <a class="button button-primary" href={contacts.instagram} target="_blank" rel="noreferrer">
          Записатися
        </a>
        <a class="button" href="#services">
          Подивитися послуги
        </a>
      </div>
    </div>

    <div class="card" style="padding: 0; overflow: hidden; min-height: 420px;">
    <img
      src={`${import.meta.env.BASE_URL}images/kateryna.jpg`}
      alt="Катерина — ведичний астролог"
      style="width: 100%; height: 100%; display: block; object-fit: cover;"
    />
    </div>
  </div>
</section>
